# Environment
.env
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# Data — review CSVs require API keys and can be regenerated; exclude them
# Per-year inspection files and processed features ARE committed
# inspections.csv is the merged output — regenerated by build_features.py, not committed
data/raw/inspections.csv
data/raw/yelp_reviews.csv
data/raw/google_reviews.csv
data/raw/.claude/
data/processed/features.csv
data/outputs/

# Models — serialized sklearn/joblib artifacts are committed (small, required for app)
# DistilBERT checkpoint is tracked via Git LFS (see .gitattributes)
# ONNX export artifacts in models/ are regeneratable — only docs/models/ is deployed
models/*.onnx
models/*.onnx.gz
# Pre-computed restaurant data gzip (raw JSON is committed; .gz is a temp artifact)
docs/static/data/restaurants.json.gz

# Notebooks checkpoints
notebooks/.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code — local settings are personal and should not be shared
.claude/settings.local.json
# Writeup — only the compiled PDF is tracked; sources are local-only
writeup/*
!writeup/*.pdf
